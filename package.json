{
  "name": "tazzledazzle.github.io",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "check": "astro check",
    "test:unit": "node --test src/lib/**/*.test.ts src/lib/blog/*.test.ts src/lib/seo/*.test.ts",
    "generate:og-default": "node scripts/generate-og-default.mjs",
    "audit:contrast": "node scripts/audit-contrast.mjs",
    "check:alt": "node scripts/check-dist-alt.mjs",
    "check:links": "lychee --config lychee.toml dist",
    "test:a11y": "playwright test tests/a11y",
    "check:lighthouse": "node scripts/run-lighthouse-ci.mjs",
    "verify:phase3": "npm run build && node scripts/verify-phase3-hiring.mjs",
    "verify:phase4": "npm run build && node scripts/verify-phase4-blog.mjs",
    "verify:phase5": "npm run build && node scripts/verify-phase5-design.mjs"
  },
  "dependencies": {
    "@astrojs/mdx": "^7.0.1",
    "@astrojs/rss": "^4.0.19",
    "@astrojs/sitemap": "^3.7.3",
    "@fontsource/inter": "^5.2.8",
    "@tailwindcss/vite": "^4.3.2",
    "astro": "^7.0.5",
    "astro-expressive-code": "^0.44.0",
    "js-yaml": "^5.2.1",
    "tailwindcss": "^4.3.2"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@axe-core/playwright": "^4.12.1",
    "@lhci/cli": "^0.14.0",
    "@playwright/test": "^1.61.1",
    "sharp": "^0.34.5",
    "typescript": "^5.9.0"
  }
}
