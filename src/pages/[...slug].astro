---
// @ts-nocheck
import PostLayout from "../layouts/PostLayout.astro";
import { getCollection, getEntry, render } from "astro:content";
import { calculateReadTime } from "../lib/blog/readTime.ts";
import { resolvePostTags } from "../lib/blog/tags.ts";
import { getPrevNextPosts, toPostNavEntry } from "../lib/blog/posts.ts";
import { deriveDescription } from "../lib/seo/description.ts";
import {
  buildArticleSchema,
  countWords
} from "../lib/seo/jsonLd.ts";

export async function getStaticPaths() {
  const inventory = await getEntry("blogInventory", "default");
  const posts = await getCollection("blog");
  const postById = new Map(posts.map((post) => [post.id, post]));
  const items = inventory?.data.posts ?? [];
  return items
    .filter((item) => postById.has(item.id))
    .map((item) => ({
      params: { slug: item.permalink.replace(/^\//, "").replace(/\/$/, "") },
      props: { id: item.id }
    }));
}

const allPosts = await getCollection("blog");
const social = await getEntry("social", "default");
const post = await getEntry("blog", Astro.props.id);
if (!post) throw new Error("Post not found");
const { Content } = await render(post);

const permalink = post.data.permalink ?? `/${post.id}/`;
const isArchived = post.data.tier === "archived";
const readTimeMinutes = calculateReadTime(post.body ?? "");
const tags = resolvePostTags(post.data.tags);
const { prev, next } = getPrevNextPosts(allPosts, permalink);
const postDescription = isArchived
  ? undefined
  : deriveDescription(post.body ?? "", post.data.description);

const site = Astro.site ?? new URL("https://tazzledazzle.github.io");
const canonicalUrl = new URL(permalink, site).href;
const authorName = social?.data.name ?? "Terence Schumacher";

const articleJsonLd = isArchived
  ? undefined
  : buildArticleSchema({
      title: post.data.title,
      description: postDescription,
      pubDate: post.data.pubDate.toISOString(),
      authorName,
      url: canonicalUrl,
      wordCount: countWords(post.body ?? ""),
      tags,
      image: new URL("/og-default.png", site).href
    });
---

<PostLayout
  title={post.data.title}
  description={postDescription}
  jsonLd={articleJsonLd}
  pubDate={post.data.pubDate}
  readTimeMinutes={readTimeMinutes}
  tags={tags}
  isArchived={isArchived}
  robots={isArchived ? "noindex" : undefined}
  prev={prev ? toPostNavEntry(prev) : null}
  next={next ? toPostNavEntry(next) : null}
>
  <Content />
</PostLayout>
