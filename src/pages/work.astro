---
import MainLayout from "../layouts/MainLayout.astro";
import { getCollection } from "astro:content";
import ProjectCard from "../components/ProjectCard.astro";
import ArchiveProjects from "../components/ArchiveProjects.astro";

const featured = await getCollection("featuredProjects");
const sorted = featured.sort((a, b) => a.data.title.localeCompare(b.data.title));
---

<MainLayout title="Work | Terence Schumacher" description="Featured software projects and portfolio work.">
  <h1>Work</h1>
  <p>Platform engineering demos tied to release automation, build systems, and DORA metrics — the work I ship in production.</p>

  <div class="work-grid">
    {sorted.map((project) => (
      <ProjectCard project={project} />
    ))}
  </div>

  <ArchiveProjects />
</MainLayout>

<style>
  .work-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
    margin-top: 1.5rem;
  }

  @media (min-width: 768px) {
    .work-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
</style>
