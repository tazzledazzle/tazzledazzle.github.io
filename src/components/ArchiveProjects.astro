---
import { getCollection } from "astro:content";

const archive = await getCollection("archiveProjects");
const sorted = archive.sort((a, b) => a.data.title.localeCompare(b.data.title));
---

<details class="archive-projects">
  <summary>More projects</summary>
  <div class="archive-projects__list">
    {sorted.map((project) => (
      <article class="archive-projects__item">
        <h3>{project.data.title}</h3>
        <p>{project.data.summary}</p>
        <ul class="archive-projects__tags" aria-label="Tech stack">
          {project.data.tech_stack.map((tech: string) => (
            <li>{tech}</li>
          ))}
        </ul>
        <div class="archive-projects__actions">
          <a href={project.data.github_url} rel="noopener noreferrer">GitHub</a>
          {project.data.demo_url && (
            <a href={project.data.demo_url} rel="noopener noreferrer">Live demo</a>
          )}
        </div>
      </article>
    ))}
  </div>
</details>

<style>
  .archive-projects {
    margin-top: 2.5rem;
  }

  .archive-projects summary {
    cursor: pointer;
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--fg);
  }

  .archive-projects__list {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    margin-top: 1rem;
  }

  .archive-projects__item {
    padding: 1rem 0;
    border-bottom: 1px solid color-mix(in srgb, var(--fg) 10%, transparent);
  }

  .archive-projects__item h3 {
    margin: 0 0 0.5rem;
    color: var(--fg);
  }

  .archive-projects__item p {
    margin: 0 0 0.75rem;
  }

  .archive-projects__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin: 0 0 0.75rem;
    padding: 0;
    list-style: none;
  }

  .archive-projects__tags li {
    padding: 0.2rem 0.6rem;
    border-radius: 999px;
    font-size: 0.8rem;
    background: color-mix(in srgb, var(--accent) 18%, transparent);
    color: var(--fg);
  }

  .archive-projects__actions {
    display: flex;
    gap: 1rem;
  }

  .archive-projects__actions a {
    font-weight: 600;
    text-decoration: none;
  }
</style>
