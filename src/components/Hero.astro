---
import { getEntry } from "astro:content";

const social = await getEntry("social", "default");
---

<section class="hero">
  <p class="hero__greeting">Hi, I'm {social?.data.name ?? "Terence Schumacher"}</p>
  <h1 class="hero__role">Platform-focused Software Engineer</h1>
  <p class="hero__specialty">
    I specialize in infrastructure and observability, building platform tooling and developer
    experience that helps teams ship with confidence.
  </p>
  <p class="hero__impact">
    I build reliable platforms teams ship on — combining SRE discipline with pragmatic tooling
    and clear technical writing.
  </p>
  <div class="hero__ctas">
    <a class="hero__cta hero__cta--primary" href="/resume.pdf">Download Resume</a>
    {social && (
      <a class="hero__cta" href={social.data.github.url} rel="noopener noreferrer">GitHub</a>
    )}
  </div>
</section>

<style>
  .hero {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding-bottom: 1.5rem;
  }

  .hero__greeting {
    margin: 0;
    font-size: 0.95rem;
    color: var(--muted);
  }

  .hero__role {
    margin: 0;
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    line-height: 1.15;
    color: var(--fg);
  }

  .hero__specialty,
  .hero__impact {
    margin: 0;
    max-width: 60ch;
  }

  .hero__ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-top: 0.5rem;
  }

  .hero__cta {
    display: inline-flex;
    align-items: center;
    padding: 0.6rem 1.1rem;
    border: 1px solid color-mix(in srgb, var(--accent) 45%, transparent);
    border-radius: 0.375rem;
    font-weight: 600;
    text-decoration: none;
  }

  .hero__cta--primary {
    background: color-mix(in srgb, var(--accent) 18%, transparent);
  }
</style>
