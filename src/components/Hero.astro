---
import { getEntry } from "astro:content";

const social = await getEntry("social", "default");
---

<section class="hero">
  <p class="hero__greeting">Hi, I'm {social?.data.name ?? "Terence Schumacher"}</p>
  <p class="hero__exploring">
    Currently exploring AI workflow reliability and DORA-driven release automation at scale.
  </p>
  <h1 class="hero__role">Senior Platform &amp; Reliability Engineer</h1>
  <p class="hero__specialty">
    I take messy build and release systems — monorepos, CI/CD pipelines, observability stacks —
    and make them measurable, automatable, and safe to ship on.
  </p>
  <p class="hero__impact">
    Seven years from Tableau's desktop release engineering to Invisible's AI data platform:
    Bazel migrations, canary rollouts, maturity audits, and the tooling that turns "it works
    on my machine" into "we know before production does."
  </p>
  <div class="hero__ctas">
    <a class="btn btn-primary" href="/resume.pdf">Download Resume</a>
    {social && (
      <a class="btn" href={social.data.github.url} rel="noopener noreferrer">GitHub</a>
    )}
  </div>
</section>
