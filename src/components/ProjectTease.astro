---
import { getCollection } from "astro:content";
import ProjectCard from "./ProjectCard.astro";

const featured = await getCollection("featuredProjects");
const teaseOrder = [
  "bazel-multibuild",
  "canary-deployment-controller",
  "release-lead-time-calculator"
];
const byId = new Map(featured.map((project) => [project.id, project]));
const teaseProjects = teaseOrder
  .map((id) => byId.get(id))
  .filter((project): project is NonNullable<typeof project> => project !== undefined);
---

<section class="project-tease reveal" aria-labelledby="project-tease-heading">
  <div class="project-tease__header">
    <h2 id="project-tease-heading">Featured work</h2>
    <a href="/work/">View all work</a>
  </div>
  <div class="project-tease__grid">
    {teaseProjects.map((project) => (
      <ProjectCard project={project} compact />
    ))}
  </div>
</section>
