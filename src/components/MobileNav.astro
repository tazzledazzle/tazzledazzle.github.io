---
import type { CollectionEntry } from "astro:content";
import { isActiveNavPath } from "../lib/nav.ts";

interface Props {
  navItems: CollectionEntry<"navigation">[];
  currentPath: string;
}

const { navItems, currentPath } = Astro.props;
---

<details class="mobile-nav">
  <summary aria-label="Menu">Menu</summary>
  <nav class="mobile-nav__panel" aria-label="Mobile">
    {navItems.map((item) => {
      const active = isActiveNavPath(currentPath, item.data.url);
      return (
        <a
          href={item.data.url}
          class:list={[active && "is-active"]}
          aria-current={active ? "page" : undefined}
        >
          {item.data.title}
        </a>
      );
    })}
    <a href="/resume.pdf" class="btn btn-primary">Download Resume</a>
  </nav>
</details>
