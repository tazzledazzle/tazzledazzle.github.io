---
import { getEntry, type CollectionEntry } from "astro:content";
import { formatCareerRange } from "../lib/formatCareerDate";

const career = await getEntry("career", "default");
const roles = career?.data.roles ?? [];
const education = career?.data.education ?? [];
---

<section class="career-timeline" aria-label="Career history">
  <ol class="career-timeline__list">
    {roles.map((role: CollectionEntry<"career">["data"]["roles"][number]) => (
      <li class="career-timeline__item reveal">
        <div class="career-timeline__dates">
          <time datetime={role.start_date}>{formatCareerRange(role.start_date, role.end_date)}</time>
        </div>
        <div class="career-timeline__content">
          <h2>{role.title}</h2>
          <p class="career-timeline__employer">{role.employer}</p>
          <ul>
            {role.bullets.map((bullet: string) => (
              <li>{bullet}</li>
            ))}
          </ul>
        </div>
      </li>
    ))}
  </ol>

  {education.length > 0 && (
    <section class="career-timeline__education" aria-labelledby="education-heading">
      <h2 id="education-heading">Education</h2>
      <ul>
        {education.map((entry: CollectionEntry<"career">["data"]["education"][number]) => (
          <li>
            <strong>{entry.institution}</strong> — {entry.degree}
          </li>
        ))}
      </ul>
    </section>
  )}
</section>
