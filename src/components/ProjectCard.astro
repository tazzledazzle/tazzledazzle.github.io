---
import type { CollectionEntry } from "astro:content";

type ProjectEntry = CollectionEntry<"featuredProjects"> | CollectionEntry<"archiveProjects">;

interface Props {
  project: ProjectEntry;
  compact?: boolean;
}

const { project, compact = false } = Astro.props;
const { title, summary, tech_stack, github_url, demo_url } = project.data;
---

<article class:list={["card", "project-card", compact && "project-card--compact"]}>
  <h3 class="project-card__title">{title}</h3>
  <p class="project-card__summary">{summary}</p>
  {tech_stack.length > 0 && (
    <ul class="project-card__tags" aria-label="Tech stack">
      {tech_stack.map((tech: string) => (
        <li class="project-card__tag">{tech}</li>
      ))}
    </ul>
  )}
  <div class="project-card__actions">
    <a class="btn" href={github_url} rel="noopener noreferrer">GitHub</a>
    {demo_url && (
      <a class="btn btn-primary" href={demo_url} rel="noopener noreferrer">Live demo</a>
    )}
  </div>
</article>
