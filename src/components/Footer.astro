---
import { getEntry } from "astro:content";

const social = await getEntry("social", "default");
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="site-footer__inner">
    <p class="site-footer__copy">
      &copy; {year} {social?.data.name ?? "Terence Schumacher"}
    </p>
    {social && (
      <div class="site-footer__social">
        <a href={social.data.github.url} rel="noopener noreferrer">GitHub</a>
        <a href={social.data.linkedin.url} rel="noopener noreferrer">LinkedIn</a>
        <a href={`mailto:${social.data.email}`}>Email</a>
      </div>
    )}
  </div>
</footer>
