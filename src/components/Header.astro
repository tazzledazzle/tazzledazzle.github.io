---
import { getCollection, getEntry, type CollectionEntry } from "astro:content";
import MobileNav from "./MobileNav.astro";
import { isActiveNavPath } from "../lib/nav.ts";

const navItems = (await getCollection("navigation")).sort(
  (a: CollectionEntry<"navigation">, b: CollectionEntry<"navigation">) =>
    a.data.order - b.data.order
);
const social = await getEntry("social", "default");
const currentPath = Astro.url.pathname;
---

<header class="site-header site-header--sticky">
  <div class="site-header__inner">
    <a href="/" class="site-header__brand" transition:name="site-brand">{social?.data.name ?? "Terence Schumacher"}</a>

    <nav class="site-header__nav" aria-label="Primary">
      {navItems.map((item: CollectionEntry<"navigation">) => {
        const active = isActiveNavPath(currentPath, item.data.url);
        return (
          <a
            href={item.data.url}
            class:list={[active && "is-active"]}
            aria-current={active ? "page" : undefined}
          >
            {item.data.title}
          </a>
        );
      })}
      <a href="/resume.pdf" class="btn btn-primary site-header__resume">Download Resume</a>
    </nav>

    <div class="site-header__social">
      {social && (
        <>
          <a href={social.data.github.url} rel="noopener noreferrer">GitHub</a>
          <a href={social.data.linkedin.url} rel="noopener noreferrer">LinkedIn</a>
          <a href={`mailto:${social.data.email}`}>Email</a>
        </>
      )}
    </div>

    <MobileNav navItems={navItems} currentPath={currentPath} />
  </div>
</header>
